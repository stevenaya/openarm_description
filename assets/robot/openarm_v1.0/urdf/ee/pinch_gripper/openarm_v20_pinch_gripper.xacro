<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="pinch_gripper"> <xacro:macro name="openarm_v20_pinch_gripper" params="connected_to:='' arm_type arm_prefix:='' ee_type ee_inertials ee_kinematics ee_kinematics_link ee_joints_limits rpy_ee:='0 0 0' xyz_ee:='0 0 0' tcp_xyz:='0 0 0' tcp_rpy:='0 0 0' description_pkg:=openarm_description">

    <xacro:property name="ee_prefix" value=""/>
    <xacro:unless value="${arm_type == ''}">
      <xacro:property name="ee_prefix" value="openarm_${arm_prefix}" />
    </xacro:unless>

    <xacro:property name="reflect" value="${-1 if arm_prefix == 'left_' else 1}" />

    <link name="${ee_prefix}hand_tcp" />
    <joint name="${ee_prefix}hand_tcp_joint" type="fixed">
      <origin xyz="${tcp_xyz}" rpy="${tcp_rpy}" />
      <parent link="${connected_to}" /> <child link="${ee_prefix}hand_tcp" />
    </joint>

    <xacro:ee_finger_link_with_sc
        name="right_finger"
        prefix="${ee_prefix}"
        ee_kinematics_link="${ee_kinematics_link}"
        arm_reflect="${reflect}"
        finger_reflect="-1"
    />
    <xacro:ee_finger_link_with_sc
        name="left_finger"
        prefix="${ee_prefix}"
        ee_kinematics_link="${ee_kinematics_link}"
        arm_reflect="${reflect}"
        finger_reflect="1"
    />

  <joint name="${ee_prefix}finger_joint1" type="revolute">
      <parent link="${connected_to}" />
      <child link="${ee_prefix}right_finger" />
      <xacro:openarm-ee-kinematics config="${ee_kinematics}" name="finger_joint" />
      <axis xyz="0 1 0" />
      <limit effort="${ee_joints_limits['finger_joint']['limit']['effort']}"
            lower="${ee_joints_limits['finger_joint']['limit']['lower']}"
            upper="${ee_joints_limits['finger_joint']['limit']['upper']}"
            velocity="${ee_joints_limits['finger_joint']['limit']['velocity']}" />
  </joint>

  <joint name="${ee_prefix}finger_joint2" type="revolute">
      <parent link="${connected_to}" />
      <child link="${ee_prefix}left_finger" />
      <xacro:property name="fj" value="${ee_kinematics['finger_joint']['kinematic']}" />
      <origin xyz="${fj.x} ${-fj.y} ${fj.z}" rpy="${fj.roll} ${fj.pitch} ${fj.yaw}" />
      <axis xyz="0 -1 0" />
      <limit effort="${ee_joints_limits['finger_joint']['limit']['effort']}"
            lower="${ee_joints_limits['finger_joint']['limit']['lower']}"
            upper="${ee_joints_limits['finger_joint']['limit']['upper']}"
            velocity="${ee_joints_limits['finger_joint']['limit']['velocity']}" />
      <mimic joint="${ee_prefix}finger_joint1" />
  </joint>

